# ─────────────────────────────────────────────────────────────────────────────
# Tony Alvarado — Variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env.local para desarrollo local.
# NUNCA subas .env.local al repositorio.
# El archivo .gitignore ya debe excluir archivos .env*.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Resend (envío de formulario de contacto) ──────────────────────────────────
# Obtener en: https://resend.com → API Keys
# Documentación: docs/integraciones-pendientes.md
RESEND_API_KEY=

# ── Email receptor de contactos ───────────────────────────────────────────────
# Email al que llegan los mensajes del formulario de contacto.
CONTACT_TO_EMAIL=

# ── Email remitente ───────────────────────────────────────────────────────────
# Mientras el dominio tonyalvarado.com no esté verificado en Resend,
# usar: onboarding@resend.dev
# Una vez verificado el dominio, cambiar a: contacto@tonyalvarado.com
CONTACT_FROM_EMAIL=

# ── Respuesta automática al interesado (autoreply) ────────────────────────────
# Solo se activa cuando RESEND_CONTACT_AUTOREPLY_ENABLED vale exactamente "true".
# Cualquier otro valor (vacío, false, 0, ausente) la mantiene desactivada.
# REQUISITO: el dominio tonyalvarado.com debe estar verificado en Resend antes
# de activar el autoreply. Activarlo sin dominio verificado provoca error 403.
#
# Pasos para activar cuando el dominio esté verificado:
# 1. Verificar tonyalvarado.com en https://resend.com → Domains
# 2. Establecer RESEND_CONTACT_AUTOREPLY_FROM con la dirección verificada
# 3. Cambiar RESEND_CONTACT_AUTOREPLY_ENABLED a "true" en Vercel → Settings → Environment Variables
# 4. Hacer un redeploy en Vercel para que los cambios tomen efecto
RESEND_CONTACT_AUTOREPLY_ENABLED=false
RESEND_CONTACT_AUTOREPLY_FROM="Tony Alvarado <info@tonyalvarado.com>"
RESEND_CONTACT_AUTOREPLY_REPLY_TO="info@tonyalvarado.com"

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID de la propiedad GA4 del cliente.
# Formato: G-XXXXXXXXXX
# Obtener en: Google Analytics → Administración → Flujos de datos
# Documentación: docs/integraciones-pendientes.md
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── URL pública del sitio ─────────────────────────────────────────────────────
# URL base del sitio en producción. No cambiar salvo migración de dominio.
NEXT_PUBLIC_SITE_URL=https://tonyalvarado.com

# ── WhatsApp (contacto directo) ───────────────────────────────────────────────
# Número en formato internacional sin espacios ni guiones.
# Ejemplo: 50688887777 (código de país + número)
# Pendiente de confirmación con el cliente.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Panel de administración disponible en /studio
# Documentación: https://sanity.io/manage → proyecto pwq90id0
NEXT_PUBLIC_SANITY_PROJECT_ID=pwq90id0
NEXT_PUBLIC_SANITY_DATASET=production
