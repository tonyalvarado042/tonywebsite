# ─────────────────────────────────────────────────────────────────────────────
# Tony Alvarado — Variables de entorno
# ─────────────────────────────────────────────────────────────────────────────
# Copia este archivo como .env.local para desarrollo local.
# NUNCA subas .env.local al repositorio.
# El archivo .gitignore ya debe excluir archivos .env*.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Resend (envío de formulario de contacto) ──────────────────────────────────
# Obtener en: https://resend.com → API Keys
# Documentación: docs/integraciones-pendientes.md
RESEND_API_KEY=

# ── Email receptor de contactos ───────────────────────────────────────────────
# Email al que llegan los mensajes del formulario de contacto.
# Pendiente de confirmación con el cliente.
CONTACT_EMAIL=

# ── Google Analytics 4 ───────────────────────────────────────────────────────
# Measurement ID de la propiedad GA4 del cliente.
# Formato: G-XXXXXXXXXX
# Obtener en: Google Analytics → Administración → Flujos de datos
# Documentación: docs/integraciones-pendientes.md
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# ── URL pública del sitio ─────────────────────────────────────────────────────
# URL base del sitio en producción. No cambiar salvo migración de dominio.
NEXT_PUBLIC_SITE_URL=https://tonyalvarado.com

# ── WhatsApp (contacto directo) ───────────────────────────────────────────────
# Número en formato internacional sin espacios ni guiones.
# Ejemplo: 50688887777 (código de país + número)
# Pendiente de confirmación con el cliente.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# ── Sanity CMS ────────────────────────────────────────────────────────────────
# Panel de administración disponible en /studio
# Documentación: https://sanity.io/manage → proyecto pwq90id0
NEXT_PUBLIC_SANITY_PROJECT_ID=pwq90id0
NEXT_PUBLIC_SANITY_DATASET=production
